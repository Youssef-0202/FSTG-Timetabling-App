FROM python:3.10-slim

WORKDIR /app

# Install system dependencies (build-essential, etc. if compiling packages is needed)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install with extended timeout to prevent PyTorch/sentence-transformers download timeouts
COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir --default-timeout=1000 -r /app/requirements.txt

# Copy source code
COPY . /app

EXPOSE 8005

# Start FastAPI chatbot server
CMD ["uvicorn", "chat_server:app", "--host", "0.0.0.0", "--port", "8005"]
